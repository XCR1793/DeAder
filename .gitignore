/.venv/
__pycache__/
*.pyc
.python-version

# Python tooling / caches
/.pytest_cache/
/.mypy_cache/
/.ruff_cache/
/.coverage
coverage.xml

# Node tooling (if you add later)
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
