session_cookies.txt
session_cookies*.txt
cookies*.txt
.env
.env.*
*.log

# Downloads folder: ignore everything (media + metadata + partials)
# Keep the folder itself in the repo via .gitkeep so the app has a place to write.
/downloads/*
!/downloads/.gitkeep

# Libre Office Calc (Temporary File)
*.ods#

